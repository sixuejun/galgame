<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="style.css" />
    <title>Document</title>
</head>
<body>
    <!-- 图片自行到 https://www.pinterest.com/ 下载 -->
    <div class="container"></div>

    <script>
        /* 创建元素，由于元素结构都是一样的，所以用代码创建
        结构如下:
        <div class="carousel-item">
          <div class="carousel-box">
            < img src="./images/1.jpg">
          </div>
        </div>
        */
        const itemCount = 15;
        container = document.querySelector(".container");
        carousel = document.createElement("div");
        carousel.classList.add("carousel");
        carousel.style.setProperty("--items", itemCount);
        for (let i = 0; i < itemCount; i++) {
            const item = document.createElement("div");
            item.classList.add("carousel-item");
            carousel.appendChild(item);

            const box = document.createElement("div");
            box.classList.add("carousel-box");
            item.appendChild(box);

            const img = document.createElement("img");
            img.src = `./images/${i + 1}.jpg`;
            box.appendChild(img);
        }
        container.appendChild(carousel);
    </script>
    <script src="./main.js"></script>
</body>
</html>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background: linear-gradient(135deg, black, #220033);
    overflow: hidden;
}

.container {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
}

.carousel {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
    overflow: hidden;
}

.carousel-item {
    --width: 24vw;
    --height: 32vw;
    --x: calc(var(--active) * 800%);
    --y: calc(var(--active) * 200%);
    --rot: calc(var(--active) * 120deg);
    --opacity: calc(var(--zIndex) / var(--items) * 3 - 2);

    position: absolute;
    z-index: var(--zIndex);
    width: var(--width);
    height: var(--height);
    margin: calc(var(--height) * -0.5) 0 0 calc(var(--width) * -0.5);
    border-radius: 10px;
    top: 50%;
    left: 50%;
    user-select: none;
    transform-origin: 0% 100%;
    box-shadow: 0 10px 50px 10px rgba(0, 0, 0, 0.5);
    background: black;
    pointer-events: all;
    transform: translate(var(--x), var(--y)) rotate(var(--rot));
    transition: transform 0.8s cubic-bezier(0, 0.02, 0, 1);
    cursor: pointer;
    overflow: hidden;
}

.carousel-item .carousel-box {
    position: absolute;
    z-index: 1;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    transition: opacity 0.8s cubic-bezier(0, 0.02, 0, 1);
    opacity: var(--opacity);
}

.carousel-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
}
/*----------------------
变量
----------------------*/
let progress = 50;
let startX = 0;
let active = 0;
let isDown = false;

/*----------------------
常量
----------------------*/
const speedWheel = 0.02;
const speedDrag = -0.1;

/*----------------------
获取Items
----------------------*/
const items = document.querySelectorAll(".carousel-item");

/*----------------------
获取z-index
这个函数用于计算每个项目的 z-index。
通过迭代数组 array, 对每个元素根据传入的 index 返回不同的 z-index 值,
确保当前活跃的项 z-index 最大,
而其余项根据与活跃项的距离来设定, 从而实现层叠效果。
----------------------*/
const getZindex = (array, index) =>
    array.map((_, i) =>
        index === i ? array.length : array.length - Math.abs(index - i)
    );

/*----------------------
高亮并前置显示当前的对象
这个函数负责根据当前活跃项来设置每个项目的 z-index 和活跃状态。
它计算并应用每个元素的 CSS 属性, 从而使当前元素突出显示并前置显示。
----------------------*/
const displayItems = (item, index, active) => {
    const zIndex = getZindex([...items], active)[index];
    item.style.setProperty("--zIndex", zIndex);
    item.style.setProperty("--active", (index - active) / items.length);
};

/*----------------------
动画效果
函数负责更新进度状态并重新计算活跃项。
它会调用 displayItems 来更新所有项目的显示状态和动画效果,
并初始化一次以确保状态的准确性。
----------------------*/
const animate = () => {
    progress = Math.max(0, Math.min(progress, 100));
    active = Math.floor((progress / 100) * (items.length - 1));

    items.forEach((item, index) => displayItems(item, index, active));
};
animate();

/*----------------------
点击事件处理
这部分代码为每个轮播项添加了点击事件监听器。
当用户点击某个项时, 它会更新 progress,
并重新调用 animate 函数以更新轮播图的状态。
----------------------*/
items.forEach((item, i) => {
    item.addEventListener("click", () => {
        progress = (i / items.length) * 100 + 10;
        animate();
    });
});

/*----------------------
事件处理函数 handleWheel, 它专门用于处理鼠标滚轮的滚动事件。
----------------------*/
const handleWheel = (e) => {
    const wheelProgress = e.deltaY * speedWheel;
    progress = progress + wheelProgress;
    animate();
};

/*----------------------
用于处理鼠标移动事件
----------------------*/
const handleMouseMove = (e) => {
    if (!isDown) return;
    const x = e.clientX || (e.touches && e.touches[0].clientX) || 0;
    const mouseProgress = (x - startX) * speedDrag;
    progress = progress + mouseProgress;
    startX = x;
    animate();
};

/*----------------------
处理鼠标按下事件
----------------------*/
const handleMouseDown = (e) => {
    isDown = true;
    startX = e.clientX || (e.touches && e.touches[0].clientX) || 0;
};

/*----------------------
处理鼠标松开事件
----------------------*/
const handleMouseUp = () => {
    isDown = false;
};

/*----------------------
添加监听事件
----------------------*/
document.addEventListener("mousewheel", handleWheel);
document.addEventListener("mousedown", handleMouseDown);
document.addEventListener("mousemove", handleMouseMove);
document.addEventListener("mouseup", handleMouseUp);
document.addEventListener("touchstart", handleMouseDown);
document.addEventListener("touchmove", handleMouseMove);
document.addEventListener("touchend", handleMouseUp);