# ========================================
# 伊甸园系统 - 环境变量配置示例
# ========================================
# 
# 说明：
# 1. 复制此文件为 `.env` 或 `.env.local` 以使用自定义配置
# 2. 所有环境变量都是可选的，未设置时将使用默认值
# 3. 环境变量必须以 `VITE_` 开头才能在客户端代码中访问
#
# ========================================

# ----------------------------------------
# 数据文件配置
# ----------------------------------------

# 数据文件路径（可选，默认为 'data.yaml'）
# 用于指定游戏初始数据文件的位置
# 支持相对路径和绝对路径
# VITE_DATA_FILE_PATH=data.yaml

# ----------------------------------------
# 应用配置
# ----------------------------------------

# 应用标题（可选，默认为 '伊甸园系统'）
# 用于设置浏览器标签页标题
# VITE_APP_TITLE=伊甸园系统

# ----------------------------------------
# 调试配置
# ----------------------------------------

# 调试模式（可选，默认为 'false'）
# 设置为 'true' 时启用详细的控制台日志输出
# 设置为 'false' 时仅输出警告和错误信息
# VITE_DEBUG=false

# ----------------------------------------
# 其他配置
# ----------------------------------------

# 在此添加其他环境变量...

