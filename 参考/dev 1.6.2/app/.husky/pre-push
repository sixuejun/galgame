# 切换到 app 目录
cd "$(dirname "$0")/.." || {
  echo "❌ Failed to change directory to app"
  exit 1
}

echo "➡️  Running pre-push hooks..."

# 1. 运行完整的 TypeScript 类型检查
echo "🧐 Running full TypeScript type check..."
pnpm type-check || {
  echo "❌ TypeScript check failed. Please fix type errors before pushing."
  exit 1
}

# 2. 运行完整的测试套件
echo "🧪 Running test suite..."
pnpm test:run || {
  echo "❌ Tests failed. Please fix failing tests before pushing."
  exit 1
}

# 3. 运行代码格式检查
echo "💅 Running format check..."
pnpm format:check || {
  echo "❌ Format check failed. Run 'pnpm format' to fix."
  exit 1
}

# 4. 运行 ESLint 检查
echo "🔍 Running ESLint check..."
pnpm lint:check || {
  echo "❌ ESLint check failed. Run 'pnpm lint' to fix."
  exit 1
}

echo "✅ All pre-push checks passed successfully!"
echo "🚀 Ready to push!"

